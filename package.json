{
  "name": "smart-city",
  "version": "1.0.0",
  "description": "Smart City – Gestion intelligente des alertes urbaines",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:api\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 http://localhost:3000/api/health && cross-env NODE_ENV=development electron .",
    "dev:api": "node --watch api/server.js",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "sync:agents": "node db/scripts/syncAgents.js",
    "audit:api": "node db/scripts/auditApi.js",
    "docs": "echo Swagger UI: http://localhost:3000/api/docs",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.1.5",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.51.2",
    "react-router-dom": "^7.6.1",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.3.0",
    "yaml": "^2.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/ui": "^1.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "^8.56.0",
    "postcss": "^8.5.4",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^1.1.0",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
